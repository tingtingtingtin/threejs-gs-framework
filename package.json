{
  "name": "@tingtingtingtin/splatkit",
  "private": false,
  "version": "0.1.2",
  "type": "module",
  "description": "Experimental Three.js Gaussian Splat viewer with embeddable headless and UI wrappers.",
  "main": "./dist-lib/index.js",
  "module": "./dist-lib/index.js",
  "types": "./dist-lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist-lib/index.d.ts",
      "import": "./dist-lib/index.js"
    },
    "./style.css": "./src/style.css"
  },
  "files": [
    "dist-lib/index.js",
    "dist-lib/index.d.ts",
    "dist-lib/SplatViewer.d.ts",
    "dist-lib/SplatViewerUI.d.ts",
    "dist-lib/classes/",
    "dist-lib/utils/",
    "dist-lib/assets/",
    "src/style.css",
    "README.md"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:lib": "tsc && vite build --config vite.lib.config.ts",
    "preview": "vite preview",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/"
  },
  "devDependencies": {
    "@types/node": "^25.0.2",
    "@types/three": "^0.182.0",
    "jsdom": "^27.3.0",
    "prettier": "^3.8.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vite": "^7.2.4",
    "vite-plugin-dts": "^4.5.4"
  },
  "peerDependencies": {
    "three": "^0.182.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tingtingtingtin/splatkit.git"
  },
  "keywords": [
    "gaussian-splatting",
    "three.js",
    "webgl",
    "3d",
    "splat"
  ],
  "author": "tingtingtingtin",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/tingtingtingtin/splatkit/issues"
  },
  "homepage": "https://github.com/tingtingtingtin/splatkit#readme"
}
